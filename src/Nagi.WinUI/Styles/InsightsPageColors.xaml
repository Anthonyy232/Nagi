<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ═══  Hyperlink Styles  ═══ -->

    <!-- Clickable name links inside insight cards (artist, album, genre).
         Inherits the scale-on-hover animation from AnimatedHyperlinkButtonStyle
         and uses primary text colour so it looks identical to a plain TextBlock at rest. -->
    <Style x:Key="InsightsHyperlinkButtonStyle" TargetType="HyperlinkButton"
           BasedOn="{StaticResource AnimatedHyperlinkButtonStyle}">
        <Setter Property="Foreground" Value="{ThemeResource TextFillColorPrimaryBrush}" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="HorizontalAlignment" Value="Left" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <!-- ═══  Card Styles  ═══ -->

    <!-- A reusable card container with rounded corners and subtle background. -->
    <Style x:Key="InsightsCardStyle" TargetType="Grid">
        <Setter Property="Background" Value="{ThemeResource CardBackgroundFillColorDefaultBrush}" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Padding" Value="20" />
        <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}" />
        <Setter Property="BorderThickness" Value="1" />
    </Style>

    <!-- A compact hero stat card that sits in the top row. -->
    <Style x:Key="InsightsHeroCardStyle" TargetType="Grid">
        <Setter Property="Background" Value="{ThemeResource CardBackgroundFillColorDefaultBrush}" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Padding" Value="20,16" />
        <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="MinHeight" Value="120" />
    </Style>

    <!-- ═══  Typography Styles  ═══ -->

    <!-- Large numeric value displayed in hero stat cards. -->
    <Style x:Key="InsightsHeroValueStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="22" />
        <Setter Property="FontWeight" Value="Bold" />
    </Style>

    <!-- Label beneath a hero stat value. -->
    <Style x:Key="InsightsHeroCaptionStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Foreground" Value="{ThemeResource TextFillColorSecondaryBrush}" />
    </Style>

    <!-- Section header inside a card. -->
    <Style x:Key="InsightsCardHeaderStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="16" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Margin" Value="0,0,0,12" />
    </Style>

</ResourceDictionary>
