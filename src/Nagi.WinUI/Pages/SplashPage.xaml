<Page
    x:Class="Nagi.WinUI.Pages.SplashPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="Transparent">

    <Grid x:Name="RootGrid">
        <Grid.RowDefinitions>
            <RowDefinition x:Name="AppTitleBarRow" Height="48" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TitleBar x:Name="AppTitleBar" Grid.Row="0" Background="Transparent" />

        <Grid Grid.Row="1">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="24">
                <Image Source="/Assets/AppLogo.png" Width="100" Height="100"/>
                <ProgressRing IsActive="True" Width="40" Height="40" HorizontalAlignment="Center"/>
                <TextBlock Text="Waking up Nagi..." Style="{ThemeResource SubtitleTextBlockStyle}" HorizontalAlignment="Center"/>
            </StackPanel>
        </Grid>
    </Grid>
</Page>
