<!-- Nagi/Pages/InsightsPage.xaml -->
<Page
    x:Class="Nagi.WinUI.Pages.InsightsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:resources="using:Nagi.WinUI.Resources"
    xmlns:vm="using:Nagi.WinUI.ViewModels"
    xmlns:controls="using:ImageEx"
    xmlns:converters="using:Nagi.WinUI.Converters"
    x:Name="InsightsPageRoot"
    Background="Transparent"
    mc:Ignorable="d">

    <Grid Padding="{StaticResource PageContainerPaddingVertical}">
        <VisualStateManager.VisualStateGroups>
            <VisualStateGroup x:Name="AdaptiveStates">
                <!-- Wide: >= 1000px -->
                <VisualState x:Name="WideState">
                    <VisualState.StateTriggers>
                        <AdaptiveTrigger MinWindowWidth="1000" />
                    </VisualState.StateTriggers>
                </VisualState>

                <!-- Medium: 600 - 999px -->
                <VisualState x:Name="MediumState">
                    <VisualState.StateTriggers>
                        <AdaptiveTrigger MinWindowWidth="600" />
                    </VisualState.StateTriggers>
                    <VisualState.Setters>
                        <Setter Target="HeroCol2.Width" Value="0" />
                        <Setter Target="HeroCol3.Width" Value="0" />
                        <Setter Target="HeroCard3.(Grid.Column)" Value="0" />
                        <Setter Target="HeroCard3.(Grid.Row)" Value="1" />
                        <Setter Target="HeroCard4.(Grid.Column)" Value="1" />
                        <Setter Target="HeroCard4.(Grid.Row)" Value="1" />
                    </VisualState.Setters>
                </VisualState>

                <!-- Narrow: < 600px -->
                <VisualState x:Name="NarrowState">
                    <VisualState.StateTriggers>
                        <AdaptiveTrigger MinWindowWidth="0" />
                    </VisualState.StateTriggers>
                    <VisualState.Setters>
                        <!-- Hero stats 2x2 -->
                        <Setter Target="HeroCol2.Width" Value="0" />
                        <Setter Target="HeroCol3.Width" Value="0" />
                        <Setter Target="HeroCard3.(Grid.Column)" Value="0" />
                        <Setter Target="HeroCard3.(Grid.Row)" Value="1" />
                        <Setter Target="HeroCard4.(Grid.Column)" Value="1" />
                        <Setter Target="HeroCard4.(Grid.Row)" Value="1" />

                        <!-- Stacking Lists -->
                        <Setter Target="Row2Col1.Width" Value="0" />
                        <Setter Target="TopArtistsCard.(Grid.Column)" Value="0" />
                        <Setter Target="TopArtistsCard.(Grid.Row)" Value="1" />
                        
                        <Setter Target="Row3Col1.Width" Value="0" />
                        <Setter Target="TopGenresCard.(Grid.Column)" Value="0" />
                        <Setter Target="TopGenresCard.(Grid.Row)" Value="1" />
                    </VisualState.Setters>
                </VisualState>
            </VisualStateGroup>
        </VisualStateManager.VisualStateGroups>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- ═══════════════  PAGE HEADER  ═══════════════ -->
        <Grid Grid.Row="0" Margin="{StaticResource PageHeaderMarginIndented}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       Text="{x:Bind resources:Strings.InsightsPage_Title, Mode=OneTime}"
                       Style="{StaticResource PageTitleTextStyle}" />

            <!-- Time range selector + reset button -->
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <ComboBox x:Name="TimeRangeSelector"
                          ItemsSource="{x:Bind ViewModel.TimeRangeLabels}"
                          SelectedIndex="{x:Bind ViewModel.SelectedTimeRangeIndex, Mode=TwoWay}"
                          MinWidth="140" />
                <Button Command="{x:Bind ViewModel.ResetListenHistoryCommand}"
                        Style="{StaticResource SubtleButtonStyle}"
                        ToolTipService.ToolTip="{x:Bind resources:Strings.InsightsPage_Reset_ToolTip, Mode=OneTime}">
                    <FontIcon Glyph="&#xE74D;" FontSize="14" />
                </Button>
            </StackPanel>
        </Grid>

        <!-- ═══════════════  LOADING INDICATOR  ═══════════════ -->
        <ProgressRing
            Grid.Row="1"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
            Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}" />

        <!-- ═══════════════  DASHBOARD CONTENT  ═══════════════ -->
        <ScrollViewer Grid.Row="1"
                      HorizontalScrollBarVisibility="Disabled"
                      VerticalScrollBarVisibility="Auto"
                      Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay, Converter={StaticResource InverseBooleanToVisibilityConverter}}">

            <!-- Show dashboard when data exists -->
            <Grid Visibility="{x:Bind ViewModel.HasData, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}">
                <StackPanel Padding="24,12,24,132" Spacing="20">
                    <StackPanel.ChildrenTransitions>
                        <TransitionCollection>
                            <EntranceThemeTransition FromVerticalOffset="40" />
                        </TransitionCollection>
                    </StackPanel.ChildrenTransitions>

                    <!-- ─────────  ROW 1: Hero Stats  ───────── -->
                    <Grid x:Name="HeroGrid" ColumnSpacing="16" RowSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" x:Name="HeroCol0" />
                            <ColumnDefinition Width="*" x:Name="HeroCol1" />
                            <ColumnDefinition Width="*" x:Name="HeroCol2" />
                            <ColumnDefinition Width="*" x:Name="HeroCol3" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <!-- Total Listen Time -->
                        <Grid x:Name="HeroCard1" Grid.Column="0" Grid.Row="0" Style="{StaticResource InsightsHeroCardStyle}">
                            <Grid ColumnSpacing="16" VerticalAlignment="Center" HorizontalAlignment="Center">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <FontIcon Grid.Column="0" Glyph="&#xE767;" FontSize="32"
                                          Foreground="{ThemeResource AppPrimaryColorBrush}"
                                          VerticalAlignment="Center" />
                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                                    <TextBlock Text="{x:Bind ViewModel.TotalListenTimeText, Mode=OneWay}"
                                               Style="{StaticResource InsightsHeroValueStyle}" />
                                    <TextBlock Text="{x:Bind resources:Strings.InsightsPage_TotalTime, Mode=OneTime}"
                                               Style="{StaticResource InsightsHeroCaptionStyle}" />
                                </StackPanel>
                            </Grid>
                        </Grid>

                        <!-- Unique Songs -->
                        <Grid x:Name="HeroCard2" Grid.Column="1" Grid.Row="0" Style="{StaticResource InsightsHeroCardStyle}">
                            <Grid ColumnSpacing="16" VerticalAlignment="Center" HorizontalAlignment="Center">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <FontIcon Grid.Column="0" Glyph="&#xE8D6;" FontSize="32"
                                          Foreground="{ThemeResource AppPrimaryColorBrush}"
                                          VerticalAlignment="Center" />
                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                                    <TextBlock Text="{x:Bind ViewModel.UniqueSongsPlayed.ToString(), Mode=OneWay}"
                                               Style="{StaticResource InsightsHeroValueStyle}" />
                                    <TextBlock Text="{x:Bind resources:Strings.InsightsPage_UniqueSongs, Mode=OneTime}"
                                               Style="{StaticResource InsightsHeroCaptionStyle}" />
                                </StackPanel>
                            </Grid>
                        </Grid>

                        <!-- Peak Hour -->
                        <Grid x:Name="HeroCard3" Grid.Column="2" Grid.Row="0" Style="{StaticResource InsightsHeroCardStyle}">
                            <Grid ColumnSpacing="16" VerticalAlignment="Center" HorizontalAlignment="Center">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <FontIcon Grid.Column="0" Glyph="&#xE823;" FontSize="32"
                                          Foreground="{ThemeResource AppPrimaryColorBrush}"
                                          VerticalAlignment="Center" />
                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                                    <TextBlock Text="{x:Bind ViewModel.PeakHourText, Mode=OneWay}"
                                               Style="{StaticResource InsightsHeroValueStyle}" />
                                    <TextBlock Text="{x:Bind resources:Strings.InsightsPage_PeakHour, Mode=OneTime}"
                                               Style="{StaticResource InsightsHeroCaptionStyle}" />
                                </StackPanel>
                            </Grid>
                        </Grid>

                        <!-- Most Active Day -->
                        <Grid x:Name="HeroCard4" Grid.Column="3" Grid.Row="0" Style="{StaticResource InsightsHeroCardStyle}">
                            <Grid ColumnSpacing="16" VerticalAlignment="Center" HorizontalAlignment="Center">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <FontIcon Grid.Column="0" Glyph="&#xE787;" FontSize="32"
                                          Foreground="{ThemeResource AppPrimaryColorBrush}"
                                          VerticalAlignment="Center" />
                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                                    <TextBlock Text="{x:Bind ViewModel.MostActiveDayText, Mode=OneWay}"
                                               Style="{StaticResource InsightsHeroValueStyle}" />
                                    <TextBlock Text="{x:Bind resources:Strings.InsightsPage_MostActiveDay, Mode=OneTime}"
                                               Style="{StaticResource InsightsHeroCaptionStyle}" />
                                </StackPanel>
                            </Grid>
                        </Grid>
                    </Grid>

                    <!-- ─────────  ROW 2: Top Songs + Top Artists (side-by-side)  ───────── -->
                    <Grid x:Name="Row2Grid" ColumnSpacing="16" RowSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" x:Name="Row2Col1" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <!-- Top Songs Card -->
                        <Grid x:Name="TopSongsCard" Grid.Column="0" Grid.Row="0" Style="{StaticResource InsightsCardStyle}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0"
                                       Text="{x:Bind resources:Strings.InsightsPage_TopSongs, Mode=OneTime}"
                                       Style="{StaticResource InsightsCardHeaderStyle}" />

                            <ListView Grid.Row="1"
                                      ItemsSource="{x:Bind ViewModel.TopSongs, Mode=OneWay}"
                                      SelectionMode="None"
                                      ScrollViewer.VerticalScrollMode="Disabled"
                                      ScrollViewer.VerticalScrollBarVisibility="Hidden"
                                      IsItemClickEnabled="False">
                                <ListView.ItemContainerStyle>
                                    <Style TargetType="ListViewItem" BasedOn="{StaticResource DefaultListViewItemStyle}">
                                        <Setter Property="Padding" Value="0" />
                                        <Setter Property="MinHeight" Value="0" />
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                    </Style>
                                </ListView.ItemContainerStyle>
                                <ListView.ItemTemplate>
                                    <DataTemplate x:DataType="vm:TopSongItem">
                                        <Grid Padding="0,8" ColumnSpacing="12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="24" />
                                                <ColumnDefinition Width="40" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <!-- Rank -->
                                            <TextBlock Grid.Column="0"
                                                       Text="{x:Bind Rank.ToString()}"
                                                       VerticalAlignment="Center"
                                                       HorizontalAlignment="Center"
                                                       Foreground="{ThemeResource AppPrimaryColorBrush}"
                                                       FontWeight="Bold" FontSize="14" />

                                            <!-- Artwork -->
                                            <Grid Grid.Column="1" Width="40" Height="40" HorizontalAlignment="Center">
                                                <Border CornerRadius="4"
                                                        Visibility="{x:Bind IsArtworkAvailable, Converter={StaticResource BooleanToVisibilityConverter}, Mode=OneWay}">
                                                    <controls:ImageEx
                                                        IsCacheEnabled="True"
                                                        Source="{x:Bind ArtworkUri, Mode=OneWay, Converter={StaticResource StringToImageSourceConverter}, FallbackValue=null}"
                                                        DecodePixelWidth="40"
                                                        DecodePixelType="Logical"
                                                        Stretch="UniformToFill" />
                                                </Border>
                                                <Grid Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                                        CornerRadius="4"
                                                        Visibility="{x:Bind IsArtworkAvailable, Converter={StaticResource InverseBooleanToVisibilityConverter}, Mode=OneWay}">
                                                    <FontIcon Glyph="&#xE8D6;" FontSize="16"
                                                                Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                                                HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                </Grid>
                                            </Grid>

                                            <!-- Title + Artist -->
                                            <StackPanel Grid.Column="2" VerticalAlignment="Center" Spacing="1">
                                                <TextBlock Text="{x:Bind Title}"
                                                           TextTrimming="CharacterEllipsis"
                                                           FontSize="13" FontWeight="SemiBold" />
                                                <TextBlock Text="{x:Bind Artist}"
                                                           TextTrimming="CharacterEllipsis"
                                                           FontSize="12"
                                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                            </StackPanel>

                                            <!-- Play count -->
                                            <StackPanel Grid.Column="3" VerticalAlignment="Center"
                                                        HorizontalAlignment="Right" Spacing="2">
                                                <TextBlock HorizontalAlignment="Right"
                                                           Text="{x:Bind PlayCountText}"
                                                           FontSize="13" FontWeight="SemiBold"
                                                           Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                                            </StackPanel>
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </Grid>

                        <!-- Top Artists Card -->
                        <Grid x:Name="TopArtistsCard" Grid.Column="1" Grid.Row="0" Style="{StaticResource InsightsCardStyle}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0"
                                       Text="{x:Bind resources:Strings.InsightsPage_TopArtists, Mode=OneTime}"
                                       Style="{StaticResource InsightsCardHeaderStyle}" />

                            <ListView Grid.Row="1"
                                      ItemsSource="{x:Bind ViewModel.TopArtists, Mode=OneWay}"
                                      SelectionMode="None"
                                      ScrollViewer.VerticalScrollMode="Disabled"
                                      ScrollViewer.VerticalScrollBarVisibility="Hidden"
                                      IsItemClickEnabled="False">
                                <ListView.ItemContainerStyle>
                                    <Style TargetType="ListViewItem" BasedOn="{StaticResource DefaultListViewItemStyle}">
                                        <Setter Property="Padding" Value="0" />
                                        <Setter Property="MinHeight" Value="0" />
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                    </Style>
                                </ListView.ItemContainerStyle>
                                <ListView.ItemTemplate>
                                    <DataTemplate x:DataType="vm:TopArtistItem">
                                        <Grid Padding="0,8" ColumnSpacing="12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="24" />
                                                <ColumnDefinition Width="40" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <!-- Rank -->
                                            <TextBlock Grid.Column="0"
                                                       Text="{x:Bind Rank.ToString()}"
                                                       VerticalAlignment="Center"
                                                       HorizontalAlignment="Center"
                                                       Foreground="{ThemeResource AppPrimaryColorBrush}"
                                                       FontWeight="Bold" FontSize="14" />

                                            <!-- Artist image -->
                                            <Grid Grid.Column="1" Width="40" Height="40" HorizontalAlignment="Center">
                                                <Border CornerRadius="20"
                                                        Visibility="{x:Bind IsArtworkAvailable, Converter={StaticResource BooleanToVisibilityConverter}, Mode=OneWay}">
                                                    <controls:ImageEx
                                                        IsCacheEnabled="True"
                                                        Source="{x:Bind ImageUri, Mode=OneWay, Converter={StaticResource StringToImageSourceConverter}, FallbackValue=null}"
                                                        DecodePixelWidth="40"
                                                        DecodePixelType="Logical"
                                                        Stretch="UniformToFill" />
                                                </Border>
                                                <Grid Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                                        CornerRadius="20"
                                                        Visibility="{x:Bind IsArtworkAvailable, Converter={StaticResource InverseBooleanToVisibilityConverter}, Mode=OneWay}">
                                                    <FontIcon Glyph="&#xE77B;" FontSize="16"
                                                                Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                                                HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                </Grid>
                                            </Grid>

                                            <!-- Name -->
                                            <HyperlinkButton Grid.Column="2"
                                                             Content="{x:Bind Name}"
                                                             Command="{Binding ViewModel.GoToArtistCommand, ElementName=InsightsPageRoot}"
                                                             CommandParameter="{x:Bind}"
                                                             Style="{StaticResource InsightsHyperlinkButtonStyle}"
                                                             FontSize="13" FontWeight="SemiBold" />

                                            <!-- Duration -->
                                            <TextBlock Grid.Column="3"
                                                       VerticalAlignment="Center"
                                                       HorizontalAlignment="Right"
                                                       FontSize="12"
                                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                       Text="{x:Bind Duration, Converter={StaticResource TimeSpanToTimeStringConverter}}" />
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </Grid>
                    </Grid>

                    <!-- ─────────  ROW 3: Top Albums + Top Genres (side-by-side)  ───────── -->
                    <Grid x:Name="Row3Grid" ColumnSpacing="16" RowSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" x:Name="Row3Col1" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <!-- Top Albums Card -->
                        <Grid x:Name="TopAlbumsCard" Grid.Column="0" Grid.Row="0" Style="{StaticResource InsightsCardStyle}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0"
                                       Text="{x:Bind resources:Strings.InsightsPage_TopAlbums, Mode=OneTime}"
                                       Style="{StaticResource InsightsCardHeaderStyle}" />

                            <ListView Grid.Row="1"
                                      ItemsSource="{x:Bind ViewModel.TopAlbums, Mode=OneWay}"
                                      SelectionMode="None"
                                      ScrollViewer.VerticalScrollMode="Disabled"
                                      ScrollViewer.VerticalScrollBarVisibility="Hidden"
                                      IsItemClickEnabled="False">
                                <ListView.ItemContainerStyle>
                                    <Style TargetType="ListViewItem" BasedOn="{StaticResource DefaultListViewItemStyle}">
                                        <Setter Property="Padding" Value="0" />
                                        <Setter Property="MinHeight" Value="0" />
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                    </Style>
                                </ListView.ItemContainerStyle>
                                <ListView.ItemTemplate>
                                    <DataTemplate x:DataType="vm:TopAlbumItem">
                                        <Grid Padding="0,8" ColumnSpacing="12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="24" />
                                                <ColumnDefinition Width="40" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <!-- Rank -->
                                            <TextBlock Grid.Column="0"
                                                       Text="{x:Bind Rank.ToString()}"
                                                       VerticalAlignment="Center"
                                                       HorizontalAlignment="Center"
                                                       Foreground="{ThemeResource AppPrimaryColorBrush}"
                                                       FontWeight="Bold" FontSize="14" />

                                            <!-- Album artwork -->
                                            <Grid Grid.Column="1" Width="40" Height="40" HorizontalAlignment="Center">
                                                <Border CornerRadius="4"
                                                        Visibility="{x:Bind IsArtworkAvailable, Converter={StaticResource BooleanToVisibilityConverter}, Mode=OneWay}">
                                                    <controls:ImageEx
                                                        IsCacheEnabled="True"
                                                        Source="{x:Bind ArtworkUri, Mode=OneWay, Converter={StaticResource StringToImageSourceConverter}, FallbackValue=null}"
                                                        DecodePixelWidth="40"
                                                        DecodePixelType="Logical"
                                                        Stretch="UniformToFill" />
                                                </Border>
                                                <Grid Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                                        CornerRadius="4"
                                                        Visibility="{x:Bind IsArtworkAvailable, Converter={StaticResource InverseBooleanToVisibilityConverter}, Mode=OneWay}">
                                                    <FontIcon Glyph="&#xE93C;" FontSize="16"
                                                                Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                                                HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                </Grid>
                                            </Grid>

                                            <!-- Title + Artist -->
                                            <StackPanel Grid.Column="2" VerticalAlignment="Center" Spacing="1">
                                                <HyperlinkButton Content="{x:Bind Title}"
                                                                 Command="{Binding ViewModel.GoToAlbumCommand, ElementName=InsightsPageRoot}"
                                                                 CommandParameter="{x:Bind}"
                                                                 Style="{StaticResource InsightsHyperlinkButtonStyle}"
                                                                 FontSize="13" FontWeight="SemiBold" />
                                                <TextBlock Text="{x:Bind ArtistName}"
                                                           TextTrimming="CharacterEllipsis"
                                                           FontSize="12"
                                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                            </StackPanel>

                                            <!-- Play count -->
                                            <StackPanel Grid.Column="3" VerticalAlignment="Center"
                                                        HorizontalAlignment="Right">
                                                <TextBlock FontSize="13" FontWeight="SemiBold"
                                                           Text="{x:Bind PlayCountText}"
                                                           Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                                            </StackPanel>
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </Grid>

                        <!-- Top Genres + Source Distribution Card -->
                        <Grid x:Name="TopGenresCard" Grid.Column="1" Grid.Row="0" Style="{StaticResource InsightsCardStyle}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0"
                                       Text="{x:Bind resources:Strings.InsightsPage_TopGenres, Mode=OneTime}"
                                       Style="{StaticResource InsightsCardHeaderStyle}" />

                            <ListView Grid.Row="1"
                                      ItemsSource="{x:Bind ViewModel.TopGenres, Mode=OneWay}"
                                      SelectionMode="None"
                                      ScrollViewer.VerticalScrollMode="Disabled"
                                      ScrollViewer.VerticalScrollBarVisibility="Hidden"
                                      IsItemClickEnabled="False">
                                <ListView.ItemContainerStyle>
                                    <Style TargetType="ListViewItem" BasedOn="{StaticResource DefaultListViewItemStyle}">
                                        <Setter Property="Padding" Value="0" />
                                        <Setter Property="MinHeight" Value="0" />
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                    </Style>
                                </ListView.ItemContainerStyle>
                                <ListView.ItemTemplate>
                                    <DataTemplate x:DataType="vm:TopGenreItem">
                                        <Grid Padding="0,6" ColumnSpacing="12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="24" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <!-- Rank -->
                                            <TextBlock Grid.Column="0"
                                                       Text="{x:Bind Rank.ToString()}"
                                                       VerticalAlignment="Center"
                                                       HorizontalAlignment="Center"
                                                       Foreground="{ThemeResource AppPrimaryColorBrush}"
                                                       FontWeight="Bold" FontSize="14" />

                                            <!-- Genre name -->
                                            <HyperlinkButton Grid.Column="1"
                                                             Content="{x:Bind Name}"
                                                             Command="{Binding ViewModel.GoToGenreCommand, ElementName=InsightsPageRoot}"
                                                             CommandParameter="{x:Bind}"
                                                             Style="{StaticResource InsightsHyperlinkButtonStyle}"
                                                             FontSize="13" FontWeight="SemiBold" />

                                            <!-- Play count -->
                                            <TextBlock Grid.Column="2"
                                                       VerticalAlignment="Center"
                                                       FontSize="12"
                                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                       Text="{x:Bind PlayCountText}" />
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>

                        </Grid>
                    </Grid>

                    <!-- ─────────  ROW 4: Playback Source Distribution  ───────── -->
                    <Grid x:Name="Row4Grid" Style="{StaticResource InsightsCardStyle}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <!-- Playback Source Distribution -->
                        <TextBlock Grid.Row="0"
                                   Text="{x:Bind resources:Strings.InsightsPage_Sources, Mode=OneTime}"
                                   Style="{StaticResource InsightsCardHeaderStyle}"
                                   Visibility="{x:Bind ViewModel.SourceSegments.Count, Mode=OneWay, Converter={StaticResource CollectionCountToVisibilityConverter}}" />

                        <ItemsRepeater Grid.Row="1"
                                       ItemsSource="{x:Bind ViewModel.SourceSegments, Mode=OneWay}"
                                       Margin="0,12,0,0">
                            <ItemsRepeater.Layout>
                                <StackLayout Orientation="Vertical" Spacing="4" />
                            </ItemsRepeater.Layout>
                            <ItemsRepeater.ItemTemplate>
                                <DataTemplate x:DataType="vm:SourceSegment">
                                    <Grid ColumnSpacing="8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="90" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Column="0"
                                                   Text="{x:Bind Label}"
                                                   FontSize="12"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                   VerticalAlignment="Center" />

                                        <!-- Progress bar representing percentage -->
                                        <ProgressBar Grid.Column="1"
                                                     Value="{x:Bind Percentage}"
                                                     Maximum="100"
                                                     Height="8"
                                                     Foreground="{x:Bind SegmentBrush}"
                                                     CornerRadius="4"
                                                     VerticalAlignment="Center" />

                                        <TextBlock Grid.Column="2"
                                                   FontSize="12" FontWeight="SemiBold"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                   VerticalAlignment="Center"
                                                   Text="{x:Bind PercentageText}" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsRepeater.ItemTemplate>
                        </ItemsRepeater>
                    </Grid>

                </StackPanel>
            </Grid>

            <!-- ═══════════════  EMPTY STATE  ═══════════════ -->
            <!-- (Shown when loading is complete but there's no listening data) -->
        </ScrollViewer>

        <!-- Empty state (overlaid when no data) -->
        <StackPanel Grid.Row="1"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Spacing="16"
                    Visibility="{x:Bind ViewModel.ShowEmptyState, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}">
            <StackPanel.ChildrenTransitions>
                <TransitionCollection>
                    <EntranceThemeTransition FromVerticalOffset="20" />
                </TransitionCollection>
            </StackPanel.ChildrenTransitions>

            <FontIcon Glyph="&#xE9D9;"
                      FontSize="48"
                      Margin="0,0,0,12"
                      Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                      HorizontalAlignment="Center" />
            <TextBlock HorizontalAlignment="Center"
                       Text="{x:Bind resources:Strings.InsightsPage_Empty_Title, Mode=OneTime}"
                       Style="{StaticResource TitleTextBlockStyle}" />
            <TextBlock HorizontalAlignment="Center"
                       Text="{x:Bind resources:Strings.InsightsPage_Empty_Subtitle, Mode=OneTime}"
                       Style="{StaticResource SubtitleTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
        </StackPanel>
    </Grid>
</Page>
